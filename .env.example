# WriteLens Environment Configuration Template
# Copy this file to .env and update with your actual values

# ============================================================================
# PYTHON & SYSTEM SETTINGS
# ============================================================================
PYTHONPATH=.
DEBUG=True
LOG_LEVEL=info

# ============================================================================
# BACKEND (Express.js)
# ============================================================================
PORT=5000
NODE_ENV=development
DATABASE_URL=sqlite:///writelens.db
SERVER_HOST=localhost

# ============================================================================
# FRONTEND (React/Vite)
# ============================================================================
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=WriteLens
VITE_APP_DESCRIPTION=Adaptive Writing Analytics System

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============================================================================
# DATABASE
# ============================================================================
DB_TYPE=sqlite
DB_PATH=writelens.db
DB_BACKUP_PATH=./backups/

# ============================================================================
# ML & ANALYTICS
# ============================================================================
BAYESIAN_INFERENCE_ENABLED=true
RANDOM_FOREST_ENABLED=true
CLUSTERING_ENABLED=true

# ============================================================================
# FILE UPLOADS
# ============================================================================
UPLOAD_DIR=./uploads/
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=xlsx,xls,csv

# ============================================================================
# LOGGING
# ============================================================================
LOG_DIR=./logs/
LOG_FILE=app.log

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================
# MOODLE_API_URL=https://your-moodle-instance.com/api
# MOODLE_API_TOKEN=your-token-here
# SENDGRID_API_KEY=your-sendgrid-key
# SLACK_WEBHOOK_URL=your-slack-webhook-url
