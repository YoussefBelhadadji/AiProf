# WriteLens Environment Variables Template

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================

# API Base URL for backend communication
VITE_API_URL=http://localhost:3000/api

# Enable/disable development mode features
VITE_DEBUG=false

# ============================================================
# BACKEND SERVER CONFIGURATION
# ============================================================

# Server host and port
HOST=localhost
PORT=3000
NODE_ENV=development

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/writelens
DB_HOST=localhost
DB_PORT=5432
DB_NAME=writelens
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# SQLite (if using instead of PostgreSQL)
# SQLITE_PATH=./data/writelens.db

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================

# JWT Configuration
JWT_SECRET=your_very_secure_secret_key_min_32_characters_long
JWT_EXPIRATION=24h

# JWT Refresh Token Settings (optional)
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRATION=7d

# Password hashing (bcryptjs)
BCRYPT_ROUNDS=10

# ============================================================
# CORS & SECURITY
# ============================================================

# Allowed origins for CORS
CORS_ORIGIN=http://localhost:5173

# session/cookie settings
SESSION_SECRET=your_session_secret_key

# ============================================================
# PYTHON AI ENGINE CONFIGURATION
# ============================================================

# Path to Python executable
PYTHON_EXECUTABLE=python

# Path to AI Engine main script
PYTHON_BRIDGE_PATH=../../ai_engine/main.py

# Python virtual environment (optional)
PYTHON_VENV=./venv

# ============================================================
# AI ENGINE CONFIGURATION
# ============================================================

# Model Selection
MODEL_TYPE=bayesian  # Options: bayesian, random_forest, ensemble

# Clustering Parameters
CLUSTERING_ALGORITHM=kmeans
CLUSTERING_K=3
CLUSTERING_MAX_ITER=100

# Thresholds Configuration Path
THRESHOLDS_CONFIG=./configs/thresholds.yaml
RULES_CONFIG=./configs/rules.yaml
FEEDBACK_TEMPLATES_CONFIG=./configs/feedback_templates.yaml

# Model File Paths (once trained)
BAYESIAN_MODEL_PATH=./models/bayesian_model.pkl
RF_MODEL_PATH=./models/random_forest_model.pkl

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================

# Maximum file upload size (in bytes)
MAX_FILE_SIZE=10485760  # 10MB

# Allowed file types
ALLOWED_FILE_TYPES=.pdf,.docx,.txt,.csv,.xlsx

# Upload directory
UPLOAD_DIR=./data/uploads

# ============================================================
# LOGGING CONFIGURATION
# ============================================================

# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Log file path
LOG_FILE_PATH=./logs/app.log

# Logs for AI Engine
AI_LOG_LEVEL=debug
AI_LOG_FILE=./logs/ai_engine.log

# ============================================================
# DATA & EXPORT CONFIGURATION
# ============================================================

# Data directory paths
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_OUTPUTS_PATH=./data/outputs

# Export formats
EXPORT_FORMATS=csv,pdf,json

# ============================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@writelens.edu

# Enable/disable email notifications
ENABLE_EMAIL_NOTIFICATIONS=false

# ============================================================
# EXTERNAL API INTEGRATION (Optional)
# ============================================================

# Moodle Integration
MOODLE_URL=https://your-moodle-instance.edu
MOODLE_API_TOKEN=your_moodle_api_token
MOODLE_API_ENDPOINT=/webservice/rest/server.php

# Google Classroom Integration (optional)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================================
# SENTRY ERROR TRACKING (Optional)
# ============================================================

SENTRY_DSN=https://your_sentry_dsn@sentry.io/projectid
SENTRY_ENVIRONMENT=development

# ============================================================
# FEATURE FLAGS (Optional)
# ============================================================

FEATURE_PORTFOLIO_ASSESSMENT=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_PEER_REVIEW=false
FEATURE_PLAGIARISM_CHECK=false

# ============================================================
# DEVELOPMENT TOOLS
# ============================================================

# Enable verbose output
VERBOSE=true

# Enable mock data seeding
SEED_MOCK_DATA=false

# Skip Python AI (use mock responses)
MOCK_AI_ENGINE=false

# Enable memory profiling
ENABLE_PROFILING=false

# ============================================================
# NOTES:
# ============================================================
# 1. NEVER commit actual passwords to git
# 2. Use this file as template: cp .env.example .env
# 3. Update values for your local development environment
# 4. For production, use environment variables or secrets management
# 5. Keep sensitive keys in a .env file (git-ignored)
# 6. Share non-sensitive defaults only
# ============================================================
