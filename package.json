{
  "name": "writelens",
  "version": "1.0.0",
  "description": "WriteLens - Adaptive Writing Analytics System",
  "main": "writelen_main.py",
  "type": "module",
  "scripts": {
    "setup": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ..",
    "start": "python full_system_launcher.py",
    "dev:backend": "cd backend && npm start",
    "dev:frontend": "cd frontend && npm run dev",
    "test": "python adaptive_writing_system/tests/test_help_seeking_bayesian.py && cd backend && npm test",
    "test:backend": "cd backend && npm test",
    "test:integration": "cd backend && npm run test:integration",
    "lint": "cd frontend && npm run lint && cd ../backend && npm run lint",
    "build": "cd frontend && npm run build",
    "serve": "python writelen_main.py"
  },
  "keywords": [
    "writing-analytics",
    "adaptive-feedback",
    "bayesian-inference",
    "machine-learning"
  ],
  "author": "WriteLens Team",
  "license": "MIT",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {},
  "devDependencies": {}
}
